[submodule "open-x4-sdk"]
	path = open-x4-sdk
	# This project uses the community-maintained fork of the open-x4-sdk, which
	# tracks the upstream SDK with project-specific patches applied on top.
	# The fork is the authoritative source for this project's SDK dependency.
	url = https://github.com/Unintendedsideeffects/community-sdk.git
