[submodule "open-x4-sdk"]
	path = open-x4-sdk
	# Intentional: this project uses Unintendedsideeffects/community-sdk, a
	# personal fork of the open-x4-sdk that contains project-specific customized
	# fixes not yet merged upstream. It is the authoritative SDK source for this
	# repository and is maintained alongside the firmware.
	url = https://github.com/Unintendedsideeffects/community-sdk.git
