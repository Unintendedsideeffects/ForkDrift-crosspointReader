#!/bin/bash
# Pre-commit hook to auto-format staged C/C++ files and block commits on a failed build.
# This runs BEFORE the commit is created, so formatting changes are included in the commit.
#
# Install: git config core.hooksPath scripts/hooks
# (or copy to .git/hooks/ manually)

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# TEMPORARY: crossink port parallel sprint — skip pio build when toggle file exists.
if [ -f ".crossink-port/PRE_COMMIT_OFF" ]; then
    echo "Pre-commit skipped (.crossink-port/PRE_COMMIT_OFF). Run ./.crossink-port/port-build.sh before commit."
    exit 0
fi

prune_old_local_artifacts() {
    # Keep current build caches intact, but drop stale local CI output and logs.
    find . -maxdepth 1 \
        \( -name '.pio-*-ci' -o -name '.pio-lean-local*' -o -name '.pio-size-*' -o -name '.pio-codex*' \) \
        -type d -mtime +14 -prune -exec rm -rf {} +
    find . -maxdepth 1 \
        \( -name '.pio-*.log' -o -name 'pio.log' \) \
        -type f -mtime +14 -delete
    find . -maxdepth 2 \
        \( -path './.plans/*' -o -path './.copilot-logs/*' \) \
        -mtime +14 -exec rm -rf {} +
}

stage_deleted_tracked_files() {
    git ls-files --deleted -z -- "$@" | xargs -0 -r git add -u --
}

prune_stale_generated_html_headers() {
    if ! command -v python3 &> /dev/null; then
        return
    fi

    python3 - <<'PY'
from pathlib import Path
import re

src_dir = Path("src/network/html")
if not src_dir.exists():
    raise SystemExit


def sanitize_identifier(value: str) -> str:
    value = re.sub(r"[^A-Za-z0-9_]", "_", value)
    if not value or value[0].isdigit():
        value = f"_{value}"
    return value


expected_headers = set()
for source in src_dir.rglob("*"):
    if source.suffix == ".html":
        expected_headers.add(source.with_name(f"{sanitize_identifier(source.stem + 'Html')}.generated.h"))
    elif source.suffix == ".js":
        expected_headers.add(source.with_name(f"{sanitize_identifier(source.stem + 'Js')}.generated.h"))

removed = []
for header in src_dir.rglob("*.generated.h"):
    if header not in expected_headers:
        header.unlink()
        removed.append(str(header))

if removed:
    print("Pruned stale generated header(s):")
    for path in removed:
        print(f"  {path}")
PY

    stage_deleted_tracked_files src/network/html
}

prune_stale_screen_previews() {
    if ! command -v python3 &> /dev/null; then
        return
    fi

    python3 tools/screen-harness/write_preview_manifest.py --prune-only docs/configurator/screen-previews

    stage_deleted_tracked_files docs/configurator/screen-previews
}

prune_old_local_artifacts
prune_stale_generated_html_headers
prune_stale_screen_previews

# Guard: block staging I18nStrings.cpp without a matching translation YAML change.
# I18nStrings.cpp is generated from YAML — committing it as a side-effect of
# unrelated work embeds a stale or accidental snapshot. Always commit the YAML
# source alongside it when translations are intentionally updated.
STAGED_STRINGS=$(git diff --cached --name-only --diff-filter=ACM | grep -F 'lib/I18n/I18nStrings.cpp' || true)
if [ -n "$STAGED_STRINGS" ]; then
    STAGED_YAML=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^lib/I18n/translations/.*\.yaml$' || true)
    if [ -z "$STAGED_YAML" ]; then
        echo "Error: lib/I18n/I18nStrings.cpp is staged without any translation YAML changes."
        echo "I18nStrings.cpp is generated — do not commit it as a side-effect of unrelated work."
        echo ""
        echo "  To unstage:            git restore --staged lib/I18n/I18nStrings.cpp"
        echo "  To commit deliberately: also stage the YAML in lib/I18n/translations/"
        exit 1
    fi
fi

# Regenerate HTML headers when source HTML or theme tokens are staged.
STAGED_THEME=$(git diff --cached --name-only --diff-filter=ACM | grep -F 'scripts/theme.css' || true)
STAGED_HTML=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^src/.*\.html$' || true)
if [ -n "$STAGED_HTML" ] || [ -n "$STAGED_THEME" ]; then
    if command -v python3 &> /dev/null; then
        python3 scripts/build_html.py
        GEN_HEADERS=()
        while IFS= read -r HTML_FILE; do
            BASE_PATH="${HTML_FILE%.html}"
            GEN_HEADERS+=("${BASE_PATH}Html.generated.h")
        done <<< "$STAGED_HTML"
        # Generated headers are gitignored (built at compile time); skip staging them.
    else
        echo "Warning: python3 not found, skipping HTML header generation"
    fi
fi

# Get staged C/C++ files (excluding lib/EpdFont/builtinFonts/ which are generated)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|cpp|h|hpp)$' | grep -v -E '^lib/EpdFont/builtinFonts/' | grep -v -E '\.generated\.h$' || true)

if [ -n "$STAGED_FILES" ]; then
    # Check if clang-format is available
    if ! command -v clang-format &> /dev/null; then
        echo "Warning: clang-format not found, skipping auto-format"
    else
        # Format each staged file and re-stage it
        for FILE in $STAGED_FILES; do
            if [ -f "$FILE" ]; then
                clang-format -style=file -i "$FILE"
                git add "$FILE"
            fi
        done

        echo "Auto-formatted $(echo "$STAGED_FILES" | wc -w) file(s) with clang-format"
    fi
fi

if command -v uv &> /dev/null; then
    BUILD_CMD=(uv run pio run -e default)
else
    echo "Error: uv is required in PATH so the pre-commit build can use the pinned toolchain."
    exit 1
fi

echo "Running pre-commit build..."
"${BUILD_CMD[@]}"

echo "Pre-commit checks passed"
